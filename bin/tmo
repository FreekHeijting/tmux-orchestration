# ---------------------------------------------------------------------------
# note (soft-inject into running tmux+claude session)
# ---------------------------------------------------------------------------

usage_note() {
    cat <<'EOF'
tmo note - soft-inject a sidenote into a running tmux+claude session

Usage:
  tmo note <session> <message>           # auto-prefix [SIDENOTE HH:MM]
  tmo note <session> --raw <message>     # no prefix, raw paste
  tmo note <session> --hard <message>    # interrupt current tool/turn first (Esc Esc)

Behavior:
- Soft (default): tmux send-keys text + 2-step Enter. Queued in REPL during
  busy turn, picked up at next-turn boundary. Non-disruptive.
- Hard: Esc Esc first to abort current tool, then inject. Risky during Write/Edit.

Multiline messages: use $'line1\nline2' or wrap with `--file <path>`.

Use case:
- Orchestrator self-poke via cron: `*/4 * * * * tmo note orchestrator "check workers"`
- Sidekick reminders during long runs.
- Out-of-band steering without restarting the REPL.
EOF
}

cmd_note() {
    [[ $# -ge 2 ]] || { usage_note; die "note: session and message required"; }

    local session="" mode="soft" file=""
    local target_check
    local args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) usage_note; return 0 ;;
            --raw)     mode="raw";  shift ;;
            --hard)    mode="hard"; shift ;;
            --file)    file="$2";   shift 2 ;;
            *) args+=("$1"); shift ;;
        esac
    done

    [[ ${#args[@]} -ge 1 ]] || die "note: session required"
    session="${args[0]}"
    local message="${args[*]:1}"

    [[ -n "$file" || -n "$message" ]] || die "note: message required"

    require_cmd tmux
    target_check=$(tmux has-session -t "$session" 2>&1) || die "note: session not found: $session ($target_check)"

    local body
    if [[ -n "$file" ]]; then
        [[ -f "$file" ]] || die "note: file not found: $file"
        body=$(<"$file")
    else
        body="$message"
    fi

    if [[ "$mode" == "soft" ]]; then
        local ts
        ts=$(date +%H:%M)
        body="[SIDENOTE $ts] $body"
    fi

    if [[ "$mode" == "hard" ]]; then
        tmux send-keys -t "${session}:0.0" Escape Escape
        sleep 0.3
    fi

    if [[ "$body" == *$'\n'* ]]; then
        local buf="tmo-note-$$-$RANDOM"
        printf '%s' "$body" | tmux load-buffer -b "$buf" -
        tmux paste-buffer -b "$buf" -t "${session}:0.0"
        tmux delete-buffer -b "$buf"
    else
        tmux send-keys -t "${session}:0.0" "$body"
    fi
    sleep 0.2
    tmux send-keys -t "${session}:0.0" Enter

    if [[ -f "$MESSAGES_FILE" ]]; then
        jq -nc --arg s "$session" --arg m "$body" --arg mode "$mode" \
               --arg ts "$(iso_ts)" --arg from "${TMO_SESSION:-cli}" \
            '{event:"note", from:$from, to:$s, mode:$mode, body:$m, ts:$ts}' \
            >> "$MESSAGES_FILE"
    fi

    printf 'tmo: note injected into %s (mode=%s)\n' "$session" "$mode"
}

# ---------------------------------------------------------------------------
# task (event-sourced via tasks.jsonl, collapse-on-read)
# ---------------------------------------------------------------------------

usage_task() {
    cat <<'EOF'
tmo task - kanban-style cross-session task tracker

Usage:
  tmo task add <subject> [--desc <text>] [--by <handle>]
                         [--context <text>] [--parent <id>]
  tmo task list [--status pending|in_progress|review|completed] [--owner <name>]
  tmo task get <id>
  tmo task claim <id> [--by <name>]
  tmo task update <id> <field> <value>     # arbitrary metadata field
  tmo task decompose <parent-id> <sub1> <sub2> ...
                         [--context <text>] [--by <name>]
  tmo task review <id> --evidence <text> [--by <name>]
  tmo task approve <id> [--by <name>]
  tmo task reject <id> --reason <text> [--by <name>]
  tmo task done <id> [--output <text>]
  tmo task board [--include-completed]

Statuses: pending → in_progress → review → completed
Sub-orchs MUST NOT call 'done' directly; reserved for orchestrator after
approve. Sub-orchs call 'review' with evidence; orchestrator gates via
approve/reject. Reject loops the task back to in_progress.

Storage: state/tasks.jsonl (append-only events). State derived by replay:
last event per id wins for status/owner; arbitrary fields updatable.

Events: add | claim | update | decompose | review | approve | reject | done

ID format: T-<n> where n is count of add-events + 1.
EOF
}

_tasks_replay() {
    [[ -f "$TASKS_FILE" ]] || { printf '[]\n'; return; }
    # Hardened: only 'add' events create an entry. All other events for an
    # unknown id are silently ignored (prevents phantom rows from claim/done
    # events landing without preceding add).
    jq -s '
        reduce .[] as $e ({};
            if $e.event == "add" then
                .[$e.id] = {id:$e.id, subject:$e.subject, desc:($e.desc // ""),
                            status:"pending", owner:null, created:$e.ts, updated:$e.ts,
                            output:null, by:($e.by // "unknown"),
                            parent:($e.parent // null), context:($e.context // ""),
                            evidence:null, gate:null, reject_reason:null,
                            children:[]}
            elif (.[$e.id] // null) == null then
                .   # ignore events for unknown ids (no preceding add)
            elif $e.event == "claim" then
                .[$e.id].owner = $e.owner | .[$e.id].status = "in_progress" | .[$e.id].updated = $e.ts
            elif $e.event == "update" then
                .[$e.id][$e.field] = $e.value | .[$e.id].updated = $e.ts
            elif $e.event == "decompose" then
                .[$e.id].children = ($e.children // []) | .[$e.id].updated = $e.ts
            elif $e.event == "review" then
                .[$e.id].status = "review" | .[$e.id].evidence = ($e.evidence // "") | .[$e.id].updated = $e.ts
            elif $e.event == "approve" then
                .[$e.id].gate = "approve" | .[$e.id].updated = $e.ts
            elif $e.event == "reject" then
                .[$e.id].status = "in_progress" | .[$e.id].gate = "reject" | .[$e.id].reject_reason = ($e.reason // "") | .[$e.id].updated = $e.ts
            elif $e.event == "done" then
                .[$e.id].status = "completed" | .[$e.id].output = ($e.output // "") | .[$e.id].updated = $e.ts
            else . end)
        | [.[]] | sort_by(.id)
    ' "$TASKS_FILE"
}

_next_task_id() {
    local n
    if [[ -f "$TASKS_FILE" ]]; then
        n=$(grep -c '"event":"add"' "$TASKS_FILE" 2>/dev/null || printf 0)
    else
        n=0
    fi
    printf 'T-%d' "$((n + 1))"
}

cmd_task() {
    require_state
    [[ $# -gt 0 ]] || { usage_task; return 0; }
    local sub="$1"; shift
    case "$sub" in
        --help|-h) usage_task; return 0 ;;

        add)
            local subject="" desc="" by="${TMO_SESSION:-unknown}" context="" parent=""
            [[ $# -gt 0 ]] || die "task add: subject required"
            subject="$1"; shift
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --desc)    desc="$2";    shift 2 ;;
                    --by)      by="$2";      shift 2 ;;
                    --context) context="$2"; shift 2 ;;
                    --parent)  parent="$2";  shift 2 ;;
                    *) die "task add: unknown flag: $1" ;;
                esac
            done
            local id; id=$(_next_task_id)
            if [[ -n "$parent" ]]; then
                jq -nc --arg id "$id" --arg s "$subject" --arg d "$desc" \
                       --arg by "$by" --arg ts "$(iso_ts)" \
                       --arg ctx "$context" --arg p "$parent" \
                    '{event:"add", id:$id, subject:$s, desc:$d, by:$by, ts:$ts, context:$ctx, parent:$p}' \
                    >> "$TASKS_FILE"
            else
                jq -nc --arg id "$id" --arg s "$subject" --arg d "$desc" \
                       --arg by "$by" --arg ts "$(iso_ts)" --arg ctx "$context" \
                    '{event:"add", id:$id, subject:$s, desc:$d, by:$by, ts:$ts, context:$ctx}' \
                    >> "$TASKS_FILE"
            fi
            printf 'tmo: task added %s\n' "$id"
            ;;

        decompose)
            [[ $# -ge 2 ]] || die "task decompose: parent-id + at least one subject required"
            local parent_id="$1"; shift
            local context="" by="${TMO_SESSION:-unknown}"
            local subjects=()
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --context) context="$2"; shift 2 ;;
                    --by)      by="$2";      shift 2 ;;
                    --*)       die "task decompose: unknown flag: $1" ;;
                    *)         subjects+=("$1"); shift ;;
                esac
            done
            [[ ${#subjects[@]} -ge 1 ]] || die "task decompose: at least one subject required"
            # validate parent exists
            grep -qE "\"event\":\"add\"[^}]*\"id\":\"$parent_id\"" "$TASKS_FILE" 2>/dev/null \
                || die "task decompose: parent $parent_id has no add-event in tasks.jsonl"

            local child_ids=()
            local ts; ts=$(iso_ts)
            local s child_id
            for s in "${subjects[@]}"; do
                child_id=$(_next_task_id)
                jq -nc --arg id "$child_id" --arg s "$s" --arg d "" \
                       --arg by "$by" --arg ts "$ts" \
                       --arg ctx "$context" --arg p "$parent_id" \
                    '{event:"add", id:$id, subject:$s, desc:$d, by:$by, ts:$ts, context:$ctx, parent:$p}' \
                    >> "$TASKS_FILE"
                child_ids+=("$child_id")
            done
            # audit event recording the decomposition
            local children_json
            children_json=$(printf '%s\n' "${child_ids[@]}" | jq -R . | jq -s .)
            jq -nc --arg id "$parent_id" --arg by "$by" --arg ts "$ts" \
                   --argjson children "$children_json" \
                '{event:"decompose", id:$id, by:$by, ts:$ts, children:$children}' \
                >> "$TASKS_FILE"
            # auto-close parent with output describing children
            local output_str
            output_str="decomposed → $(IFS=, ; echo "${child_ids[*]}")"
            jq -nc --arg id "$parent_id" --arg out "$output_str" --arg ts "$ts" \
                '{event:"done", id:$id, output:$out, ts:$ts}' >> "$TASKS_FILE"
            printf 'tmo: task %s decomposed into %s\n' "$parent_id" "${child_ids[*]}"
            ;;

        review)
            [[ $# -gt 0 ]] || die "task review: id required"
            local id="$1"; shift
            local evidence="" by="${TMO_SESSION:-unknown}"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --evidence) evidence="$2"; shift 2 ;;
                    --by)       by="$2";       shift 2 ;;
                    *) die "task review: unknown flag: $1" ;;
                esac
            done
            [[ -n "$evidence" ]] || die "task review: --evidence is required (sha, bench-rate, capture-pane url)"
            jq -nc --arg id "$id" --arg ev "$evidence" --arg by "$by" --arg ts "$(iso_ts)" \
                '{event:"review", id:$id, evidence:$ev, by:$by, ts:$ts}' >> "$TASKS_FILE"
            printf 'tmo: task %s moved to review by %s\n' "$id" "$by"
            ;;

        approve)
            [[ $# -gt 0 ]] || die "task approve: id required"
            local id="$1"; shift
            local by="${TMO_SESSION:-unknown}"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --by) by="$2"; shift 2 ;;
                    *) die "task approve: unknown flag: $1" ;;
                esac
            done
            jq -nc --arg id "$id" --arg by "$by" --arg ts "$(iso_ts)" \
                '{event:"approve", id:$id, by:$by, ts:$ts}' >> "$TASKS_FILE"
            printf 'tmo: task %s approved by %s. Run: tmo task done %s --output "<merge-sha>"\n' "$id" "$by" "$id"
            ;;

        reject)
            [[ $# -gt 0 ]] || die "task reject: id required"
            local id="$1"; shift
            local reason="" by="${TMO_SESSION:-unknown}"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --reason) reason="$2"; shift 2 ;;
                    --by)     by="$2";     shift 2 ;;
                    *) die "task reject: unknown flag: $1" ;;
                esac
            done
            [[ -n "$reason" ]] || die "task reject: --reason is required"
            jq -nc --arg id "$id" --arg r "$reason" --arg by "$by" --arg ts "$(iso_ts)" \
                '{event:"reject", id:$id, reason:$r, by:$by, ts:$ts}' >> "$TASKS_FILE"
            printf 'tmo: task %s rejected by %s. Re-instruct sub-orch via tmo note.\n' "$id" "$by"
            ;;

        board)
            local include_completed=0
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --include-completed) include_completed=1; shift ;;
                    *) die "task board: unknown flag: $1" ;;
                esac
            done
            _tasks_replay | jq -r --argjson inc "$include_completed" '
                def col(status): map(select(.status == status)) | map("\(.id) \(.owner // "-")  \(.subject[:34])");
                def pad(s; n): (s + (" " * n))[:n];
                ({ pending:     (. | col("pending"))
                 , in_progress: (. | col("in_progress"))
                 , review:      (. | col("review"))
                 , completed:   (if $inc == 1 then (. | col("completed")) else [] end)
                 }) as $cols
                | ([$cols.pending|length, $cols.in_progress|length, $cols.review|length, $cols.completed|length] | max) as $h
                | "┌──────────────────────────────────────┬──────────────────────────────────────┬──────────────────────────────────────┬──────────────────────────────────────┐",
                  ("│ " + pad("PENDING (\($cols.pending|length))"; 36) + " │ " + pad("IN_PROGRESS (\($cols.in_progress|length))"; 36) + " │ " + pad("REVIEW (\($cols.review|length))"; 36) + " │ " + pad("COMPLETED (\($cols.completed|length))"; 36) + " │"),
                  "├──────────────────────────────────────┼──────────────────────────────────────┼──────────────────────────────────────┼──────────────────────────────────────┤",
                  (range(0; $h) as $i
                   | "│ " + pad(($cols.pending[$i] // ""); 36)
                   + " │ " + pad(($cols.in_progress[$i] // ""); 36)
                   + " │ " + pad(($cols.review[$i] // ""); 36)
                   + " │ " + pad(($cols.completed[$i] // ""); 36)
                   + " │"),
                  "└──────────────────────────────────────┴──────────────────────────────────────┴──────────────────────────────────────┴──────────────────────────────────────┘"
            '
            ;;

        list)
            local status_filter="" owner_filter=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --status) status_filter="$2"; shift 2 ;;
                    --owner)  owner_filter="$2";  shift 2 ;;
                    *) die "task list: unknown flag: $1" ;;
                esac
            done
            _tasks_replay | jq -r --arg s "$status_filter" --arg o "$owner_filter" '
                .[]
                | select(($s == "" or .status == $s)
                      and ($o == "" or .owner == $o))
                | "\(.id)\t[\(.status)]\t\(.owner // "-")\t\(.subject)"
            '
            ;;

        get)
            [[ $# -gt 0 ]] || die "task get: id required"
            _tasks_replay | jq --arg id "$1" '.[] | select(.id == $id)'
            ;;

        claim)
            [[ $# -gt 0 ]] || die "task claim: id required"
            local id="$1"; shift
            local by="${TMO_SESSION:-unknown}"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --by) by="$2"; shift 2 ;;
                    *) die "task claim: unknown flag: $1" ;;
                esac
            done
            jq -nc --arg id "$id" --arg owner "$by" --arg ts "$(iso_ts)" \
                '{event:"claim", id:$id, owner:$owner, ts:$ts}' >> "$TASKS_FILE"
            printf 'tmo: task %s claimed by %s\n' "$id" "$by"
            ;;

        update)
            [[ $# -ge 3 ]] || die "task update: id field value required"
            local id="$1" field="$2" value="$3"
            # field name must be a simple identifier (letters, digits, dash, underscore)
            [[ "$field" =~ ^[a-zA-Z_][a-zA-Z0-9_-]*$ ]] \
                || die "task update: field must match [a-zA-Z_][a-zA-Z0-9_-]*, got: $field"
            jq -nc --arg id "$id" --arg f "$field" --arg v "$value" --arg ts "$(iso_ts)" \
                '{event:"update", id:$id, field:$f, value:$v, ts:$ts}' >> "$TASKS_FILE"
            printf 'tmo: task %s.%s updated\n' "$id" "$field"
            ;;

        done)
            [[ $# -gt 0 ]] || die "task done: id required"
            local id="$1"; shift
            local output=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --output) output="$2"; shift 2 ;;
                    *) die "task done: unknown flag: $1" ;;
                esac
            done
            jq -nc --arg id "$id" --arg out "$output" --arg ts "$(iso_ts)" \
                '{event:"done", id:$id, output:$out, ts:$ts}' >> "$TASKS_FILE"
            printf 'tmo: task %s done\n' "$id"
            ;;

        *) die "task: unknown action: $sub. Run: tmo task --help" ;;
    esac
}

# ---------------------------------------------------------------------------
# context-check — detect Claude context usage % from tmux pane
# Reads "X% until auto-compact" indicator from Claude TUI statusline.
# Exit 0  = context < 80% used (safe to inject directly)
# Exit 1  = context >= 80% used (orchestrator must /compact + resume first)
# Exit 2  = indicator not found (treated as safe, unknown Claude version)
# ---------------------------------------------------------------------------

usage_context_check() {
    cat <<'EOF'
tmo context-check - check Claude context usage in a tmux pane

Usage:
  tmo context-check <session>

Reads "X% until auto-compact" from the Claude TUI statusline.

Exit codes:
  0  context < 80% used  (inject normally)
  1  context >= 80% used (send /compact + resume instruction first)
  2  indicator not found (safe default)

Dispatch guard pattern:
  if tmo context-check builder; then
    tmo note builder "next task: ..."
  else
    tmo context-compact builder "$(cat /tmp/resume.txt)"
  fi
EOF
}

cmd_context_check() {
    local session="${1:-}"
    [[ -n "$session" ]] || die "context-check: session name required"

    local pane_text
    pane_text=$(tmux capture-pane -t "${session}:0.0" -p -S -5 2>/dev/null \
        | sed 's/\x1b\[[0-9;]*[mABCDHJKST]//g; s/\x1b\[[0-9;]*[a-zA-Z]//g')

    local remaining
    remaining=$(printf '%s' "$pane_text" \
        | grep -oE '[0-9]+% until auto-compact' \
        | grep -oE '^[0-9]+' \
        | tail -1)

    if [[ -z "$remaining" ]]; then
        printf '[context-check] session=%s indicator=not_found (assume OK)\n' "$session" >&2
        return 2
    fi

    local used=$(( 100 - remaining ))
    printf '[context-check] session=%s remaining=%s%% used=%s%%\n' \
        "$session" "$remaining" "$used" >&2

    if (( remaining <= 20 )); then
        printf 'HIGH_CONTEXT: %s%% used — run /compact before injecting\n' "$used"
        return 1
    else
        printf 'OK: %s%% used\n' "$used"
        return 0
    fi
}

cmd_context_compact() {
    local session="${1:-}"
    local resume="${2:-}"
    [[ -n "$session" ]] || die "context-compact: session name required"

    # /compact <resume> as ONE command — resume is the compact instruction,
    # telling Claude what to preserve in the summary. Not a separate message.
    local buf="ctx-compact-${session}"
    local tmpfile="/tmp/tmo-compact-${session}.txt"
    if [[ -n "$resume" ]]; then
        printf '/compact %s' "$resume" > "$tmpfile"
    else
        printf '/compact' > "$tmpfile"
    fi
    tmux load-buffer -b "$buf" "$tmpfile"
    tmux paste-buffer -b "$buf" -t "${session}:0.0"
    sleep 0.2
    tmux send-keys -t "${session}:0.0" Enter
    tmux delete-buffer -b "$buf"
    rm -f "$tmpfile"

    # Wait for compact to finish (prompt returns)
    local i
    for i in $(seq 1 30); do
        sleep 2
        tmux capture-pane -t "${session}:0.0" -p -S -3 2>/dev/null \
            | grep -qE '^[[:space:]]*❯|^> $' && break
    done

    printf '[context-compact] session=%s /compact injected with resume\n' "$session" >&2
}

# ---------------------------------------------------------------------------
# watchdog (cron-driven idle / awaiting-user state-machine)
# Spec: skills/tmux-orchestration/references/watchdog.md
# ---------------------------------------------------------------------------

usage_watchdog() {
    cat <<'EOF'
tmo watchdog - cron-driven orchestrator state-machine

Usage:
  tmo watchdog tick <session>      Single tick: classify session, write state, act
  tmo watchdog status              Show current state for all tracked sessions
  tmo watchdog enable <session>    Initialize tracking for a session
  tmo watchdog disable <session>   Stop tracking (entry kept, enabled=false)

Cron entry (recommended):
  */10 * * * * /home/freek/.local/bin/tmo watchdog tick orchestrator >> /tmp/tmo-watchdog.log 2>&1

State files (under $TMO_STATE_DIR):
  state/orchestrator-status.yaml   Per-session status, hash, awaiting-user count
  state/parked-questions.yaml      Questions parked when user does not reply
  state/backlog.yaml               Backlog items to pick when idle (external write)

State machine (see references/watchdog.md for full table):
  active             - pane changed since last tick OR busy spinner visible
  awaiting-user      - open question (trailing ? or [AWAITING-USER]) and no reply
  idle-no-work       - REPL idle, backlog empty, parked empty
  idle-with-backlog  - REPL idle, backlog non-empty
EOF
}

_wd_yaml_init() {
    [[ -f "$WATCHDOG_STATUS_FILE" ]] || cat > "$WATCHDOG_STATUS_FILE" <<'EOF'
# tmo watchdog: per-session orchestrator status
# Schema: sessions: { <name>: { status, last_pane_hash, awaiting_user_count,
#                               current_question_id, last_checked_ts,
#                               last_active_ts, enabled } }
sessions: {}
EOF
    [[ -f "$WATCHDOG_PARKED_FILE" ]] || cat > "$WATCHDOG_PARKED_FILE" <<'EOF'
# tmo watchdog: parked questions awaiting later resume
parked: []
EOF
    [[ -f "$WATCHDOG_BACKLOG_FILE" ]] || cat > "$WATCHDOG_BACKLOG_FILE" <<'EOF'
# tmo watchdog: idle-pickup backlog (external producers)
items: []
EOF
}

_wd_status_get() {
    # _wd_status_get <session> <field>
    local session="$1" field="$2"
    python3 - "$WATCHDOG_STATUS_FILE" "$session" "$field" <<'PYEOF'
import sys, yaml
path, session, field = sys.argv[1:]
with open(path) as f:
    data = yaml.safe_load(f) or {}
val = (data.get("sessions") or {}).get(session, {}).get(field)
print("" if val is None else val)
PYEOF
}

_wd_pane_capture() {
    # capture last 200 lines of pane 0.0
    local session="$1"
    tmux capture-pane -t "${session}:0.0" -p -S -200 2>/dev/null || printf ''
}

_wd_detect_copy_mode() {
    # Echoes "1" if pane 0.0 of session is in copy-mode (or any tmux mode),
    # "0" otherwise. Reads tmux's #{pane_in_mode} format directly so we don't
    # depend on visible status-text heuristics.
    local session="$1"
    tmux display-message -p -t "${session}:0.0" -F '#{pane_in_mode}' 2>/dev/null
}

_wd_status_set_field() {
    # Generic single-field setter on sessions.<session>.<field>. Numeric
    # strings are stored as ints; everything else as the literal string.
    local session="$1" field="$2" value="$3"
    python3 - "$WATCHDOG_STATUS_FILE" "$session" "$field" "$value" <<'PYEOF'
import sys, yaml
path, session, field, value = sys.argv[1:]
with open(path) as f:
    data = yaml.safe_load(f) or {}
sessions = data.get("sessions") or {}
entry = sessions.get(session) or {}
try:
    entry[field] = int(value)
except (TypeError, ValueError):
    entry[field] = value
sessions[session] = entry
data["sessions"] = sessions
with open(path, "w") as f:
    yaml.safe_dump(data, f, sort_keys=False)
PYEOF
}

_wd_handle_copy_mode() {
    # Detect copy-mode on pane 0.0; if active and not throttled within
    # TMO_WATCHDOG_TICK_INTERVAL seconds (default 600), log a copy-mode-hang
    # event to messages.jsonl, send '-X cancel' to drop out, then log a
    # copy-mode-cancelled event. Persists last_copy_mode_cancel_epoch as the
    # throttle anchor.
    #
    # Returns 0 when copy-mode was detected this tick (caller MUST return
    # without further classification). Returns 1 when not in copy-mode.
    local session="$1"
    local in_mode; in_mode=$(_wd_detect_copy_mode "$session")
    [[ "$in_mode" == "1" ]] || return 1

    local now_epoch; now_epoch=$(date +%s)
    local interval="${TMO_WATCHDOG_TICK_INTERVAL:-600}"
    local last_ts; last_ts=$(_wd_status_get "$session" "last_copy_mode_cancel_epoch")
    if [[ -n "$last_ts" && "$last_ts" =~ ^[0-9]+$ ]]; then
        local delta=$(( now_epoch - last_ts ))
        if (( delta < interval )); then
            printf '[watchdog %s] session=%s copy-mode detected, throttled (delta=%ss < interval=%ss)\n' \
                "$(iso_ts)" "$session" "$delta" "$interval" >&2
            return 0
        fi
    fi

    local hang_payload cancel_payload
    hang_payload=$(jq -cn \
        --arg session "$session" \
        --arg detected_at "$(iso_ts)" \
        '{session:$session, detected_at:$detected_at, signal:"pane_in_mode=1"}')
    cmd_send "$session" "copy-mode-hang" "$hang_payload" >/dev/null

    tmux send-keys -t "${session}:0.0" -X cancel 2>/dev/null

    cancel_payload=$(jq -cn \
        --arg session "$session" \
        --arg cancelled_at "$(iso_ts)" \
        '{session:$session, cancelled_at:$cancelled_at, action:"send-keys -X cancel"}')
    cmd_send "$session" "copy-mode-cancelled" "$cancel_payload" >/dev/null

    _wd_status_set_field "$session" "last_copy_mode_cancel_epoch" "$now_epoch"

    printf '[watchdog %s] session=%s copy-mode cancelled\n' "$(iso_ts)" "$session" >&2
    return 0
}

_wd_detect_busy() {
    # exit 0 if Claude is actively working. Match patterns that ONLY appear
    # while Claude is generating: "esc to interrupt", "tokens · esc", or the
    # rotating spinner-glyph followed by a space and a verb. Bare glyphs are
    # NOT enough: ⏵⏵ shows up in the idle "bypass permissions" status row
    # and ✶/✻ can appear in markdown bullets, both producing false positives.
    local pane="$1"
    if printf '%s' "$pane" \
        | grep -qE 'esc to interrupt|tokens · esc|^[[:space:]]*[✻✶✢✳✺] '; then
        return 0
    fi
    return 1
}

_wd_detect_open_question() {
    # exit 0 if pane has explicit [AWAITING-USER] marker, OR last
    # non-empty non-code line ends with '?'. Pane content via stdin.
    local pane="$1"
    if printf '%s' "$pane" | grep -q '\[AWAITING-USER\]'; then
        return 0
    fi
    printf '%s' "$pane" | python3 -c '
import sys
in_fence = False
last = ""
for line in sys.stdin.read().splitlines():
    if line.lstrip().startswith("```"):
        in_fence = not in_fence
        continue
    if in_fence:
        continue
    if line.strip():
        last = line.rstrip()
sys.exit(0 if last.endswith("?") else 1)
'
}

_wd_backlog_count() {
    python3 - "$WATCHDOG_BACKLOG_FILE" <<'PYEOF'
import sys, yaml
with open(sys.argv[1]) as f:
    data = yaml.safe_load(f) or {}
print(len(data.get("items") or []))
PYEOF
}

_wd_backlog_top() {
    # print "id|task|priority" of first item, or empty
    python3 - "$WATCHDOG_BACKLOG_FILE" <<'PYEOF'
import sys, yaml
with open(sys.argv[1]) as f:
    data = yaml.safe_load(f) or {}
items = data.get("items") or []
if items:
    it = items[0]
    print(f"{it.get('id', '?')}|{it.get('task', '?')}|{it.get('priority', '?')}")
PYEOF
}

_wd_extract_question() {
    # last non-empty non-fenced line of pane content (read from stdin)
    python3 -c '
import sys
in_fence = False
last = ""
for line in sys.stdin.read().splitlines():
    if line.lstrip().startswith("```"):
        in_fence = not in_fence
        continue
    if in_fence:
        continue
    if line.strip():
        last = line.rstrip()
print(last)
'
}

_wd_park_question() {
    # _wd_park_question <session> <qid> <question>; pane content via stdin
    # Uses python3 -c so stdin remains free for the pane pipe
    # (python3 - <<heredoc would consume stdin via the heredoc).
    local session="$1" qid="$2" question="$3"
    local now; now="$(iso_ts)"
    python3 -c '
import sys, yaml
path, session, qid, question, ts = sys.argv[1:]
pane_excerpt = sys.stdin.read()[-2000:]
with open(path) as f:
    data = yaml.safe_load(f) or {}
parked = data.get("parked") or []
parked.append({
    "id": qid,
    "session": session,
    "question": question,
    "parked_at": ts,
    "pane_excerpt": pane_excerpt,
})
data["parked"] = parked
with open(path, "w") as f:
    yaml.safe_dump(data, f, sort_keys=False)
' "$WATCHDOG_PARKED_FILE" "$session" "$qid" "$question" "$now"
}

_wd_soft_inject() {
    # _wd_soft_inject <session> <message-without-prefix>
    # Reuses cmd_note (soft mode). cmd_note prepends "[SIDENOTE HH:MM]" itself.
    # This function adds the "[from watchdog]" self-identification prefix.
    local session="$1" message="$2"
    cmd_note "$session" "[from watchdog] $message" >/dev/null
}

_wd_set_parked_hash() {
    # mark pane hash as "already prodded for this question" so subsequent
    # ticks with identical pane don't keep incrementing the counter
    local session="$1" hash="$2"
    python3 - "$WATCHDOG_STATUS_FILE" "$session" "$hash" <<'PYEOF'
import sys, yaml
path, session, hash_ = sys.argv[1:]
with open(path) as f:
    data = yaml.safe_load(f) or {}
sessions = data.get("sessions") or {}
entry = sessions.get(session) or {}
entry["last_parked_pane_hash"] = hash_
sessions[session] = entry
data["sessions"] = sessions
with open(path, "w") as f:
    yaml.safe_dump(data, f, sort_keys=False)
PYEOF
}

_wd_status_update() {
    # _wd_status_update <session> <status> <pane_hash> <awaiting_count> <question_id>
    local session="$1" status="$2" pane_hash="$3" count="$4" qid="$5"
    local now; now="$(iso_ts)"

    python3 - "$WATCHDOG_STATUS_FILE" "$session" "$status" "$pane_hash" "$count" "$qid" "$now" <<'PYEOF'
import sys, yaml
path, session, status, pane_hash, count, qid, ts = sys.argv[1:]
with open(path) as f:
    data = yaml.safe_load(f) or {}
sessions = data.get("sessions") or {}
entry = sessions.get(session) or {}
entry["status"] = status
entry["last_pane_hash"] = pane_hash
entry["awaiting_user_count"] = int(count)
entry["current_question_id"] = None if qid in ("", "null") else qid
entry["last_checked_ts"] = ts
if status == "active":
    entry["last_active_ts"] = ts
entry.setdefault("enabled", True)
sessions[session] = entry
data["sessions"] = sessions
with open(path, "w") as f:
    yaml.safe_dump(data, f, sort_keys=False)
PYEOF
}

cmd_watchdog() {
    [[ $# -gt 0 ]] || { usage_watchdog; return 0; }
    require_state
    _wd_yaml_init

    local sub="$1"; shift
    case "$sub" in
        --help|-h) usage_watchdog; return 0 ;;
        tick)      _wd_tick "$@" ;;
        status)    _wd_status_show "$@" ;;
        enable)    _wd_enable "$@" ;;
        disable)   _wd_disable "$@" ;;
        *) die "watchdog: unknown action: $sub. Run: tmo watchdog --help" ;;
    esac
}

_wd_tick() {
    [[ $# -ge 1 ]] || die "watchdog tick: session required"
    local session="$1"
    local now; now="$(iso_ts)"

    require_cmd tmux

    if ! tmux has-session -t "$session" 2>/dev/null; then
        printf '[watchdog %s] session not found: %s\n' "$now" "$session" >&2
        return 1
    fi

    local enabled; enabled=$(_wd_status_get "$session" "enabled")
    if [[ "$enabled" == "False" ]]; then
        printf '[watchdog %s] session=%s disabled, skip\n' "$now" "$session" >&2
        return 0
    fi

    # copy-mode short-circuit: if pane is in copy-mode (pane_in_mode=1), the
    # capture-pane content is the static scrollback view and busy/idle
    # classification would be meaningless. Detect, log, cancel, return early.
    if _wd_handle_copy_mode "$session"; then
        return 0
    fi

    # capture pane + hash
    local pane pane_hash prev_hash
    pane=$(_wd_pane_capture "$session")
    pane_hash=$(printf '%s' "$pane" | sha1sum | awk '{print $1}')
    prev_hash=$(_wd_status_get "$session" "last_pane_hash")

    # detect signals
    local is_busy=0 is_open_q=0 changed=0
    _wd_detect_busy "$pane"          && is_busy=1
    _wd_detect_open_question "$pane" && is_open_q=1
    [[ -n "$prev_hash" && "$pane_hash" != "$prev_hash" ]] && changed=1

    # current count + question id + last parked hash (defaults)
    local count qid prev_status parked_hash
    count=$(_wd_status_get "$session" "awaiting_user_count")
    qid=$(_wd_status_get "$session" "current_question_id")
    prev_status=$(_wd_status_get "$session" "status")
    parked_hash=$(_wd_status_get "$session" "last_parked_pane_hash")
    [[ -z "$count" ]] && count=0

    # already-parked guard: if we already parked this exact pane, treat as idle
    # until pane changes (avoids re-park spam on every tick).
    local already_parked=0
    [[ -n "$parked_hash" && "$pane_hash" == "$parked_hash" ]] && already_parked=1

    # classify + question-id lifecycle
    local new_status="" action="none" new_qid="null"
    if [[ "$is_busy" == "1" || "$changed" == "1" ]]; then
        new_status="active"
        count=0
        new_qid="null"
    elif [[ "$is_open_q" == "1" && "$already_parked" == "0" ]]; then
        new_status="awaiting-user"
        count=$((count + 1))
        if [[ -z "$qid" || "$prev_status" != "awaiting-user" ]]; then
            new_qid="q-$(date +%s)-${session}"
        else
            new_qid="$qid"
        fi
        action="log"
        [[ "$count" -ge 2 ]] && action="park-and-pick"
    else
        new_qid="null"
        local backlog_n; backlog_n=$(_wd_backlog_count)
        if [[ "$backlog_n" -gt 0 ]]; then
            new_status="idle-with-backlog"
            action="prod-backlog"
        else
            new_status="idle-no-work"
            action="log"
        fi
    fi

    _wd_status_update "$session" "$new_status" "$pane_hash" "$count" "$new_qid"

    printf '[watchdog %s] session=%s status=%s count=%s qid=%s busy=%s changed=%s open_q=%s parked_match=%s action=%s\n' \
        "$now" "$session" "$new_status" "$count" "$new_qid" "$is_busy" "$changed" "$is_open_q" "$already_parked" "$action" >&2

    # action wiring (F5)
    case "$action" in
        park-and-pick)
            local question; question=$(printf '%s' "$pane" | _wd_extract_question)
            printf '%s' "$pane" | _wd_park_question "$session" "$new_qid" "$question"
            _wd_set_parked_hash "$session" "$pane_hash"
            local backlog_top; backlog_top=$(_wd_backlog_top)
            local msg
            if [[ -n "$backlog_top" ]]; then
                local b_id b_task
                b_id="${backlog_top%%|*}"
                b_task=$(printf '%s' "$backlog_top" | cut -d'|' -f2)
                msg="user not replying on Q ($new_qid). Parked to state/parked-questions.yaml. Pick top backlog item: $b_id - $b_task"
            else
                msg="user not replying on Q ($new_qid). Parked to state/parked-questions.yaml. Backlog empty; carry on or wait."
            fi
            _wd_soft_inject "$session" "$msg"
            # reset count after park (next open-q on changed pane will start fresh)
            _wd_status_update "$session" "$new_status" "$pane_hash" "0" "null"
            printf '[watchdog %s] session=%s park-and-pick done qid=%s\n' "$now" "$session" "$new_qid" >&2
            ;;
        prod-backlog)
            local backlog_n; backlog_n=$(_wd_backlog_count)
            local backlog_top; backlog_top=$(_wd_backlog_top)
            local b_id="?" b_task="(unknown)"
            if [[ -n "$backlog_top" ]]; then
                b_id="${backlog_top%%|*}"
                b_task=$(printf '%s' "$backlog_top" | cut -d'|' -f2)
            fi
            _wd_soft_inject "$session" "backlog has $backlog_n items, pick top-prio: $b_id - $b_task"
            printf '[watchdog %s] session=%s prod-backlog done\n' "$now" "$session" >&2
            ;;
        log|none) ;;
    esac
}

_wd_enable() {
    [[ $# -ge 1 ]] || die "watchdog enable: session required"
    local session="$1"
    require_cmd tmux
    tmux has-session -t "$session" 2>/dev/null \
        || die "watchdog enable: session not found: $session"

    python3 - "$WATCHDOG_STATUS_FILE" "$session" "$(iso_ts)" <<'PYEOF'
import sys, yaml
path, session, ts = sys.argv[1:]
with open(path) as f:
    data = yaml.safe_load(f) or {}
sessions = data.get("sessions") or {}
entry = sessions.get(session) or {}
entry["status"] = "active"
entry.setdefault("last_pane_hash", "")
entry["awaiting_user_count"] = 0
entry["current_question_id"] = None
entry["last_checked_ts"] = ts
entry["last_active_ts"] = ts
entry["enabled"] = True
sessions[session] = entry
data["sessions"] = sessions
with open(path, "w") as f:
    yaml.safe_dump(data, f, sort_keys=False)
PYEOF
    printf 'tmo: watchdog enabled for %s\n' "$session"
}

_wd_disable() {
    [[ $# -ge 1 ]] || die "watchdog disable: session required"
    local session="$1"
    python3 - "$WATCHDOG_STATUS_FILE" "$session" <<'PYEOF'
import sys, yaml
path, session = sys.argv[1:]
with open(path) as f:
    data = yaml.safe_load(f) or {}
sessions = data.get("sessions") or {}
if session in sessions:
    sessions[session]["enabled"] = False
    data["sessions"] = sessions
    with open(path, "w") as f:
        yaml.safe_dump(data, f, sort_keys=False)
PYEOF
    printf 'tmo: watchdog disabled for %s\n' "$session"
}

_wd_status_show() {
    python3 - "$WATCHDOG_STATUS_FILE" "$WATCHDOG_PARKED_FILE" "$WATCHDOG_BACKLOG_FILE" <<'PYEOF'
import sys, yaml
status_path, parked_path, backlog_path = sys.argv[1:4]

with open(status_path) as f:
    status = yaml.safe_load(f) or {}
with open(parked_path) as f:
    parked_data = yaml.safe_load(f) or {}
with open(backlog_path) as f:
    backlog_data = yaml.safe_load(f) or {}

sessions = status.get("sessions") or {}
parked = parked_data.get("parked") or []
backlog = backlog_data.get("items") or []

if not sessions:
    print("(no sessions tracked)")
else:
    hdr = (f"{'SESSION':<24}{'STATUS':<22}{'COUNT':<7}"
           f"{'QID':<32}{'ENABLED':<9}{'LAST_CHECKED'}")
    print(hdr)
    print("-" * len(hdr))
    for name, e in sessions.items():
        qid = e.get("current_question_id") or "-"
        print(f"{name:<24}{e.get('status', '?'):<22}"
              f"{e.get('awaiting_user_count', 0):<7}"
              f"{qid:<32}"
              f"{str(e.get('enabled', True)):<9}"
              f"{e.get('last_checked_ts', '-')}")

print()
print(f"Parked questions: {len(parked)}")
for p in parked[-5:]:
    q = (p.get("question") or "").strip()
    if len(q) > 60:
        q = q[:57] + "..."
    print(f"  {p.get('id', '?')}  [{p.get('session', '?')}]  {q}")

print()
print(f"Backlog items: {len(backlog)}")
for b in backlog[:5]:
    t = (b.get("task") or "").strip()
    if len(t) > 60:
        t = t[:57] + "..."
    print(f"  {b.get('id', '?')}  [{b.get('priority', '?')}]  {t}")
PYEOF
}

# ---------------------------------------------------------------------------
# statusline (called from tmux status-format on every refresh — must be fast)
# ---------------------------------------------------------------------------

usage_statusline() {
    cat <<'EOF'
tmo statusline - print one-line metadata for tmux status-bar

Usage:
  tmo statusline <session>

Output (single line, with #[fg=...] tmux color markup):
  task=T-X | state=working | peer=N

Intended for use in tmux status-format substitutions:
  set-option status-left "... #(tmo statusline #S)"

Performance: must complete in <100ms; cache-friendly.
EOF
}

cmd_statusline() {
    local session="${1:-}"
    [[ -n "$session" ]] || { usage_statusline; return 1; }

    local task_id="-"
    local state="?"
    local peer="0"

    # current claimed task by this session (most recent in_progress)
    if [[ -f "$TASKS_FILE" ]]; then
        task_id=$(_tasks_replay 2>/dev/null \
            | jq -r --arg s "$session" '
                map(select(.status == "in_progress" and .owner == $s))
                | sort_by(.updated) | reverse
                | .[0].id // "-"
            ' 2>/dev/null || printf '%s' "-")
        [[ -z "$task_id" || "$task_id" == "null" ]] && task_id="-"
    fi

    # state from sessions.yaml (last entry for this session wins)
    if [[ -f "$SESSIONS_FILE" ]]; then
        state=$( { grep -E "name: \"?${session}\"?" "$SESSIONS_FILE" 2>/dev/null \
            | tail -1 \
            | grep -oE 'status: "?[a-z_-]+"?' 2>/dev/null \
            | sed -E 's/status: "?([a-z_-]+)"?/\1/' \
            | head -1; } || true )
        [[ -z "$state" ]] && state="?"
    fi

    # peer-traffic count: messages targeted at this session in last 5 min
    if [[ -f "$MESSAGES_FILE" ]]; then
        local cutoff
        cutoff=$(date -u -d '5 min ago' +%s 2>/dev/null || printf 0)
        peer=$( { jq -r --arg s "$session" --argjson cutoff "$cutoff" '
            select(.to == $s and ((.ts // "" | sub("\\..*Z$"; "Z") | strptime("%Y-%m-%dT%H:%M:%SZ") | mktime) >= $cutoff))
            | .ts
        ' "$MESSAGES_FILE" 2>/dev/null | wc -l | tr -d ' '; } || printf 0 )
        [[ -z "$peer" ]] && peer="0"
    fi

    printf '#[fg=yellow]task=%s #[fg=white]| #[fg=green]state=%s #[fg=white]| #[fg=cyan]peer=%s' \
        "$task_id" "$state" "$peer"
}

# ---------------------------------------------------------------------------
# headerline (3-line task banner shown above main statusline)
# ---------------------------------------------------------------------------

usage_headerline() {
    cat <<'EOF'
tmo headerline - print Nth line of a session's task-banner

Usage:
  tmo headerline <session> [1|2|3]

Lines:
  1   "T-X: <subject>"           (or "(no claimed task)" when idle)
  2   "branch=<git-branch> | dir=<basename pwd>"
  3   "<first sentence of desc>"

Source: tmo task in_progress claimed by <session>, plus tmux
display-message #{pane_current_path} for git-branch lookup.

Used in tmux status-format[1..3] to render a 3-line banner above the
main one-line status. Must complete in <100ms (called every refresh).
EOF
}

cmd_headerline() {
    local session="${1:-}"
    local line="${2:-1}"
    [[ -n "$session" ]] || { usage_headerline; return 1; }

    local id="-" subject="" desc=""
    if [[ -f "$TASKS_FILE" ]]; then
        local data
        data=$( { _tasks_replay 2>/dev/null | jq -r --arg s "$session" '
            map(select(.status == "in_progress" and .owner == $s))
            | sort_by(.updated) | reverse
            | .[0] // null
            | if . then "\(.id)\(.subject)\(.desc // "")" else "" end
        ' 2>/dev/null; } || true )
        if [[ -n "$data" ]]; then
            id=$(printf '%s' "$data"     | awk -F$'\x01' '{print $1}')
            subject=$(printf '%s' "$data"| awk -F$'\x01' '{print $2}')
            desc=$(printf '%s' "$data"   | awk -F$'\x01' '{print $3}')
        fi
    fi

    local pane_path="?" branch="-" dir="?"
    pane_path=$( { tmux display-message -t "$session" -p '#{pane_current_path}' 2>/dev/null; } || printf '%s' "?" )
    [[ -z "$pane_path" ]] && pane_path="?"
    if [[ -d "$pane_path/.git" || -f "$pane_path/.git" ]] || git -C "$pane_path" rev-parse --git-dir >/dev/null 2>&1; then
        branch=$( { git -C "$pane_path" branch --show-current 2>/dev/null; } || true )
        [[ -z "$branch" ]] && branch="(detached)"
    fi
    dir=$( { basename "$pane_path" 2>/dev/null; } || printf '?' )

    case "$line" in
        1)
            if [[ -n "$subject" ]]; then
                local s="${subject:0:108}"
                printf '#[fg=white,bold]📋 %s: %s' "$id" "$s"
            else
                printf '#[fg=colour245] (no claimed task)'
            fi
            ;;
        2)
            printf '#[fg=colour38]branch=%s #[fg=white]| #[fg=colour244]dir=%s' "$branch" "$dir"
            ;;
        3)
            local s1
            s1=$(printf '%s' "$desc" | awk -F'\\. ' '{print $1}' | head -c 115)
            [[ -z "$s1" ]] && s1=" "
            printf '#[fg=colour245]%s' "$s1"
            ;;
        *)
            return 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# cleanup (T-23): persist session-meta into completed task, then kill tmux session
# ---------------------------------------------------------------------------

usage_cleanup() {
    cat <<'EOF'
tmo cleanup - persist session-meta into completed task, then kill tmux session

Usage:
  tmo cleanup <session> [--task <id>] [--role-md <path>]

Behavior:
  1. Find the task owned by <session>. With --task, use that id explicitly.
  2. HARD GATE: task.status must be 'completed' AND task.verdict must be 'approve'.
     On violation: refuse with non-zero exit; no destructive action.
  3. Capture meta (session name, role, cwd, branch, last-sha, all panes) and
     persist as JSON into the task's desc field.
  4. tmux kill-session -t <session>.

Used by the top-orchestrator after a sub-orch emits done AND quality-gate APPROVE.
Reverse: tmo session reopen <task-id>.
EOF
}

cmd_cleanup() {
    local session="" task_id="" role_md=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) usage_cleanup; return 0 ;;
            --task)    task_id="${2:?--task requires id}"; shift 2 ;;
            --role-md) role_md="${2:?--role-md requires path}"; shift 2 ;;
            -*)        die "cleanup: unknown flag: $1" ;;
            *)
                if [[ -z "$session" ]]; then
                    session="$1"; shift
                else
                    die "cleanup: unexpected arg: $1"
                fi
                ;;
        esac
    done

    [[ -n "$session" ]] || die "cleanup: missing <session>. See: tmo cleanup --help"

    require_cmd tmux
    require_cmd jq
    require_state

    local session_alive=0
    tmux has-session -t "$session" 2>/dev/null && session_alive=1

    # Resolve task
    local task_json=""
    if [[ -n "$task_id" ]]; then
        task_json=$(_tasks_replay | jq --arg id "$task_id" '.[] | select(.id == $id)')
    else
        task_json=$(_tasks_replay | jq --arg s "$session" '
            map(select(.owner == $s)) | sort_by(.updated) | reverse | .[0] // empty
        ')
    fi

    # Idempotent edge case: session gone AND no task to gate against → nothing to do
    if [[ -z "$task_json" || "$task_json" == "null" ]]; then
        if [[ "$session_alive" == "0" ]]; then
            printf 'tmo: cleanup: session %s not found and no task to update; nothing to do.\n' "$session" >&2
            return 0
        fi
        die "cleanup: no task found for session '$session'. Pass --task <id> explicitly."
    fi

    task_id=$(printf '%s' "$task_json" | jq -r '.id')
    local task_status task_verdict
    task_status=$(printf '%s' "$task_json" | jq -r '.status')
    task_verdict=$(printf '%s' "$task_json" | jq -r '."verdict" // ""')

    # HARD GATE
    if [[ "$task_status" != "completed" ]]; then
        die "cleanup: refuses; task $task_id status='$task_status' (need 'completed'). Run: tmo task done $task_id ..."
    fi
    if [[ "$task_verdict" != "approve" ]]; then
        die "cleanup: refuses; task $task_id verdict='$task_verdict' (need 'approve'). Run: tmo task update $task_id verdict approve"
    fi

    if [[ "$session_alive" == "0" ]]; then
        printf 'tmo: cleanup: session %s not found in tmux; nothing to kill. Task %s left as-is.\n' "$session" "$task_id" >&2
        return 0
    fi

    # Capture meta
    local cwd branch last_sha role_env panes_json closed_at
    cwd=$(tmux display-message -t "$session" -p '#{pane_current_path}' 2>/dev/null || printf '?')
    branch="-"
    last_sha="-"
    if [[ -n "$cwd" && "$cwd" != "?" ]] && git -C "$cwd" rev-parse --git-dir >/dev/null 2>&1; then
        branch=$(git -C "$cwd" branch --show-current 2>/dev/null || printf '(detached)')
        [[ -z "$branch" ]] && branch="(detached)"
        last_sha=$(git -C "$cwd" rev-parse --short HEAD 2>/dev/null || printf '-')
    fi
    role_env=$(tmux show-environment -t "$session" TMO_ROLE 2>/dev/null | sed -n 's/^TMO_ROLE=//p' || printf '')
    [[ -z "$role_env" ]] && role_env="-"

    # Resolve role_md if not given: roles/<role>.md under TMO_ROOT (search common locations)
    if [[ -z "$role_md" && "$role_env" != "-" ]]; then
        local cand
        for cand in "$ROLES_DIR/$role_env.md" \
                    "$HOME/GitHub/tmux-orchestration/roles/$role_env.md" \
                    "$cwd/roles/$role_env.md"; do
            if [[ -f "$cand" ]]; then role_md="$cand"; break; fi
        done
    fi
    [[ -z "$role_md" ]] && role_md="-"

    # All panes in session: window_index, pane_index, cwd
    panes_json=$(tmux list-panes -s -t "$session" -F '#{window_index} #{pane_index} #{pane_current_path}' 2>/dev/null \
        | jq -R -s 'split("\n") | map(select(length > 0) | split(" ")
            | {window: (.[0]|tonumber), pane: (.[1]|tonumber), cwd: (.[2:]|join(" "))})' )
    [[ -z "$panes_json" || "$panes_json" == "null" ]] && panes_json='[]'

    closed_at="$(iso_ts)"

    local meta
    meta=$(jq -nc \
        --arg session "$session" \
        --arg role "$role_env" \
        --arg cwd "$cwd" \
        --arg branch "$branch" \
        --arg last_sha "$last_sha" \
        --arg role_md "$role_md" \
        --arg closed_at "$closed_at" \
        --argjson panes "$panes_json" \
        --arg task_id "$task_id" \
        '{schema:"tmo.session-meta.v1", task_id:$task_id, session:$session,
          role:$role, role_md:$role_md, cwd:$cwd, branch:$branch,
          last_sha:$last_sha, panes:$panes, closed_at:$closed_at}')

    # Persist meta into task.desc (overwrites prior desc; full reversibility via jsonl replay)
    jq -nc --arg id "$task_id" --arg f "desc" --arg v "$meta" --arg ts "$(iso_ts)" \
        '{event:"update", id:$id, field:$f, value:$v, ts:$ts}' >> "$TASKS_FILE"
    printf 'tmo: cleanup: meta persisted into %s.desc\n' "$task_id"

    # Kill tmux session
    tmux kill-session -t "$session"
    printf 'tmo: cleanup: tmux session %s killed\n' "$session"

    # Audit event
    if [[ -f "$MESSAGES_FILE" ]]; then
        jq -nc --arg s "$session" --arg id "$task_id" --arg sha "$last_sha" \
               --arg ts "$closed_at" \
            '{event:"cleanup", session:$s, task_id:$id, last_sha:$sha, ts:$ts}' \
            >> "$MESSAGES_FILE"
    fi
}

# ---------------------------------------------------------------------------
# session (T-24 reopen, T-25 match, list-closed)
# ---------------------------------------------------------------------------

usage_session() {
    cat <<'EOF'
tmo session - manage closed-session metadata persisted in completed tasks

Usage:
  tmo session list-closed
  tmo session reopen <task-id> [--no-terminal] [--no-prompt]
  tmo session match <prompt-text> [--top <N>]

Subcommands:
  list-closed   List all completed tasks whose desc holds session-meta.
  reopen        Re-spawn gnome-terminal + tmux session at original cwd, apply
                statusline, send [REOPEN] sidenote with sha + role context.
  match         Score closed-session metas against a prompt; print top-N.
EOF
}

# Read meta JSON from a task's desc (validates schema). Outputs JSON or exits 1.
_session_meta() {
    local id="$1"
    local desc
    desc=$(_tasks_replay | jq -r --arg id "$id" '.[] | select(.id == $id) | .desc // ""')
    [[ -n "$desc" ]] || return 1
    printf '%s' "$desc" | jq -e 'select(.schema == "tmo.session-meta.v1")' 2>/dev/null
}

cmd_session() {
    [[ $# -gt 0 ]] || { usage_session; return 0; }
    local sub="$1"; shift
    case "$sub" in
        --help|-h)    usage_session; return 0 ;;
        list-closed)  _sess_list_closed "$@" ;;
        reopen)       _sess_reopen "$@" ;;
        match)        _sess_match "$@" ;;
        *) die "session: unknown action: $sub. Run: tmo session --help" ;;
    esac
}

_sess_list_closed() {
    require_state
    _tasks_replay | jq -r '
        .[]
        | select(.status == "completed" and (.desc // "" | startswith("{") and contains("tmo.session-meta.v1")))
        | (.desc | fromjson) as $m
        | "\(.id)\t\($m.session)\t\($m.role)\t\($m.branch)\t\($m.last_sha)\t\($m.closed_at)"
    '
}

_sess_reopen() {
    [[ $# -ge 1 ]] || die "session reopen: <task-id> required"
    local task_id="$1"; shift
    local no_terminal=0 no_prompt=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-terminal) no_terminal=1; shift ;;
            --no-prompt)   no_prompt=1;   shift ;;
            *) die "session reopen: unknown flag: $1" ;;
        esac
    done

    require_cmd tmux
    require_cmd jq
    require_state

    local meta
    meta=$(_session_meta "$task_id") \
        || die "session reopen: task $task_id has no valid session-meta in desc. Run cleanup first."

    local session role cwd branch last_sha role_md
    session=$(printf '%s' "$meta" | jq -r '.session')
    role=$(printf '%s'    "$meta" | jq -r '.role')
    cwd=$(printf '%s'     "$meta" | jq -r '.cwd')
    branch=$(printf '%s'  "$meta" | jq -r '.branch')
    last_sha=$(printf '%s' "$meta" | jq -r '.last_sha')
    role_md=$(printf '%s' "$meta" | jq -r '.role_md')

    if tmux has-session -t "$session" 2>/dev/null; then
        die "session reopen: tmux session '$session' already alive. Attach: tmux attach -t $session"
    fi

    [[ -d "$cwd" ]] || die "session reopen: cwd does not exist: $cwd"

    # Spawn tmux session detached at original cwd. Optionally also a gnome-terminal
    # window attached to it (skip via --no-terminal for headless use / tests).
    tmux new-session -d -s "$session" -c "$cwd" \
        "TMO_SESSION=$session TMO_ROLE=$role TMO_STATE_DIR=$STATE_DIR claude"
    _apply_statusline "$session" "$role"
    printf 'tmo: session reopen: tmux session %s created at %s\n' "$session" "$cwd"

    if [[ "$no_terminal" == "0" ]] && command -v gnome-terminal >/dev/null 2>&1; then
        gnome-terminal --working-directory="$cwd" -- tmux attach -t "$session" >/dev/null 2>&1 &
        printf 'tmo: session reopen: gnome-terminal attached to %s\n' "$session"
    fi

    if [[ "$no_prompt" == "0" ]]; then
        local prompt
        prompt="[REOPEN] continue from $last_sha on branch $branch. Role: $role ($role_md). Prior task: $task_id done. Read role-md and last 3 commits, then await next task."
        # Brief delay to let claude REPL spin up before injection
        ( sleep 3; cmd_note "$session" "$prompt" >/dev/null 2>&1 ) &
        printf 'tmo: session reopen: [REOPEN] prompt queued for %s\n' "$session"
    fi

    if [[ -f "$MESSAGES_FILE" ]]; then
        jq -nc --arg s "$session" --arg id "$task_id" --arg sha "$last_sha" \
               --arg ts "$(iso_ts)" \
            '{event:"reopen", session:$s, task_id:$id, last_sha:$sha, ts:$ts}' \
            >> "$MESSAGES_FILE"
    fi
}

_sess_match() {
    local top=3
    local query=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --top) top="${2:?--top requires N}"; shift 2 ;;
            *)
                if [[ -z "$query" ]]; then
                    query="$1"; shift
                else
                    query="$query $1"; shift
                fi
                ;;
        esac
    done
    [[ -n "$query" ]] || die "session match: <prompt-text> required"
    [[ "$top" =~ ^[1-9][0-9]*$ ]] || die "session match: --top must be positive int"

    require_state

    # Tokenize query: lowercase, split on non-alnum, drop tokens <3 chars
    local tokens_json
    tokens_json=$(printf '%s' "$query" | jq -R -c '
        ascii_downcase | [scan("[a-z0-9]+")] | map(select(length >= 3))
    ')

    _tasks_replay | jq -r --argjson toks "$tokens_json" --argjson top "$top" '
        [ .[]
          | select(.status == "completed"
                   and (.desc // "" | startswith("{")
                   and contains("tmo.session-meta.v1")))
          | (.desc | fromjson) as $m
          | (.subject + " " + ($m.role // "") + " " + ($m.branch // "")
             + " " + ($m.session // "")) as $hay
          | ($hay | ascii_downcase) as $h
          | { id: .id,
              session: $m.session,
              role: $m.role,
              last_sha: $m.last_sha,
              score: ([ $toks[] | select(. as $t | $h | contains($t)) ] | length),
              subject: .subject }
          | select(.score > 0)
        ]
        | sort_by(-.score) | .[0:$top]
        | .[]
        | "\(.score)\t\(.id)\t\(.session)\t\(.role)\t\(.last_sha)\t\(.subject)"
    '
}

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------

main() {
    if [[ $# -eq 0 ]]; then
        usage_root
        exit 0
    fi

    local sub="$1"; shift

    case "$sub" in
        --help|-h)        usage_root ;;
        --version|-v)     printf 'tmo %s\n' "$TMO_VERSION" ;;
        init)             cmd_init "$@" ;;
        spawn)            cmd_spawn "$@" ;;
        list-roles)       cmd_list_roles "$@" ;;
        send)             cmd_send "$@" ;;
        receive)          cmd_receive "$@" ;;
        wait-for)         cmd_wait_for "$@" ;;
        note)             cmd_note "$@" ;;
        task)             cmd_task "$@" ;;
        watchdog)         cmd_watchdog "$@" ;;
        context-check)    cmd_context_check "$@" ;;
        context-compact)  cmd_context_compact "$@" ;;
        statusline)       cmd_statusline "$@" ;;
        headerline)       cmd_headerline "$@" ;;
        cleanup)          cmd_cleanup "$@" ;;
        session)          cmd_session "$@" ;;
        bootstrap)        cmd_bootstrap "$@" ;;
        *) die "unknown subcommand: $sub. Run: tmo --help" ;;
    esac
}

main "$@"
